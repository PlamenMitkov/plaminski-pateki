{
  "ConnectionStrings": {
    "DefaultConnection": "Server=.\\SQLEXPRESS;Database=EcoTrailsDb;Trusted_Connection=True;TrustServerCertificate=True;MultipleActiveResultSets=true"
  },
  "Jwt": {
    "Issuer": "EcoTrails.Api",
    "Audience": "EcoTrails.Client",
    "Key": "",
    "ExpiryHours": 12
  },
  "OpenRouteService": {
    "ApiKey": "",
    "BaseUrl": "https://api.openrouteservice.org"
  },
  "OpenAI": {
    "Provider": "gemini",
    "ApiKey": "",
    "BaseUrl": "https://api.openai.com/v1",
    "OpenAiModel": "gpt-4o-mini",
    "OpenAiFallbackModel": "gpt-4o-mini",
    "GeminiApiKey": "",
    "GeminiBaseUrl": "https://generativelanguage.googleapis.com/v1beta",
    "Model": "gemini-2.5-flash",
    "GeminiModel": "gemini-2.5-flash",
    "FallbackToOpenAiOnGemini429": true,
    "FallbackToOpenAiOnGeminiUnavailable": true,
    "AssistantMode": "current",
    "PromptTemplateShadowMode": false,
    "PromptTemplateFailOpen": true,
    "PromptInjectionGuardEnabled": true,
    "PromptInjectionBlockOnDetect": false,
    "EnforceSourceProvenance": true,
    "RequireVerifiedSourceForContext": true,
    "TrustedSourceDomainAllowList": [
      "gov.bg",
      "opoznai.bg",
      "wikipedia.org",
      "npark.bg",
      "meteo.bg"
    ],
    "QuarantinedSourceDomains": [],
    "WeatherEnabled": true,
    "WeatherApiBaseUrl": "https://api.open-meteo.com/v1",
    "WeatherGeocodingBaseUrl": "https://geocoding-api.open-meteo.com/v1",
    "Temperature": 0.3,
    "MaxTokens": 4096,
    "EnrichDelayMs": 200,
    "RetryAttempts": 3,
    "RetryInitialDelayMs": 500,
    "RetryJitterMs": 200,
    "RrfK": 60,
    "VectorMultiplier": 2,
    "TopK": 5
  },
  "OpenTelemetry": {
    "ServiceName": "EcoTrails.Api",
    "Otlp": {
      "Endpoint": "",
      "Protocol": "grpc"
    }
  },
  "Cors": {
    "AllowedOrigins": [
      "http://localhost:5173",
      "http://127.0.0.1:5173",
      "https://eco.example.com"
    ],
    "AllowedMethods": [
      "GET",
      "POST",
      "PUT",
      "DELETE",
      "OPTIONS"
    ],
    "AllowedHeaders": [
      "Authorization",
      "Content-Type",
      "Accept"
    ]
  },
  "Admin": {
    "Emails": []
  },
  "AdminPanel": {
    "Username": "",
    "Password": ""
  },
  "OfflineEnrichment": {
    "WeatherAlertsSourceUrl": "https://www.meteo.bg/bg/forecasts/warnings"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "Serilog": {
    "Using": [
      "Serilog.Sinks.Console"
    ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft": "Warning",
        "System": "Warning"
      }
    },
    "Enrich": [
      "FromLogContext"
    ],
    "WriteTo": [
      {
        "Name": "Console",
        "Args": {
          "formatter": "Serilog.Formatting.Compact.RenderedCompactJsonFormatter, Serilog.Formatting.Compact"
        }
      }
    ],
    "Properties": {
      "Application": "EcoTrails.Api"
    }
  },
  "AllowedHosts": "*"
}
