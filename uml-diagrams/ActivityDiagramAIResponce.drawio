        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam style strictuml\nskinparam activity {\n  BackgroundColor LightCyan\n  BorderColor DarkCyan\n  ArrowColor DimGray\n}\n\ntitle Activity Diagram: Обработка на запитване към AI Асистента\n\nstart\n:Потребител изпраща въпрос;\n:API контролерът приема заявката;\n\npartition \&quot;Security &amp; Governance (IAssistantPromptSafetyService)\&quot; {\n    :Анализ за prompt-injection;\n    if (Опасен ли е текстът?) then (Да)\n        :Връщане на съобщение за нарушение\\nна сигурността;\n        stop\n    else (Не)\n    endif\n}\n\npartition \&quot;Data Retrieval (IAssistantRetrievalService &amp; Provenance)\&quot; {\n    :Хибридно търсене на екопътеки\\n(векторно + пълнотекстово);\n    :Филтриране на източниците\\n(Provenance Policy);\n    :Добавяне на локален метеорологичен контекст;\n}\n\npartition \&quot;AI Provider Orchestration &amp; Fallback\&quot; {\n    :Формиране на финалния промпт;\n    :Опит за извикване на основния модел (Gemini);\n    \n    if (Успешен отговор?) then (Не)\n        :Активиране на Fallback Policy;\n        :Опит за извикване на резервния модел (OpenAI);\n        \n        if (Успешен отговор?) then (Не)\n            :Връщане на стандартно съобщение\\nза временна недостъпност;\n            stop\n        else (Да)\n        endif\n    else (Да)\n    endif\n}\n\npartition \&quot;Response Composition\&quot; {\n    :Извличане на структурирани данни\\nот AI отговора;\n    :Прикачване на Schema.org метаданни;\n}\n\n:Визуализиране на отговора в UI;\nstop\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="QdD2V77MlphqFeI65beP-1">
