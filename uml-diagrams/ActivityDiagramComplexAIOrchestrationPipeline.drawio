<mxfile host="app.diagrams.net">
  <diagram name="Страница-1" id="zn-QbVLMZfZ6wnTw2-bQ">
    <mxGraphModel dx="1426" dy="743" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam style strictuml\nskinparam activity {\n  BackgroundColor LightCyan\n  BorderColor DarkCyan\n  ArrowColor DimGray\n}\n\ntitle Activity Diagram: Complex AI Orchestration Pipeline\n\nstart\n:API Controller приема заявка от потребителя;\n\npartition \&quot;1. Security &amp; Validation\&quot; {\n  :IAssistantPromptSafetyService;\n  if (Детектирана\\nPrompt Injection?) then (Да)\n    :Връщане на грешка\\n(Security Violation);\n    stop\n  else (Не)\n  endif\n}\n\npartition \&quot;2. Parallel Data Retrieval (RAG Pipeline)\&quot; {\n  &#39; Започване на паралелни асинхронни процеси\n  fork\n    :IAssistantRetrievalService;\n    :Хибридно търсене (Vector + Full-text);\n    :Anti-ambiguity филтър (Exact-token);\n    :IAssistantProvenancePolicyService\\n(Премахване на Quarantined domains);\n  fork again\n    :IWeatherContextService;\n    :Асинхронно извличане на\\nлокална метеорологична прогноза;\n  fork again\n    :User Context;\n    if (Потребителят е логнат?) then (Да)\n      :Извличане на \&quot;Любими пътеки\&quot;\\nот SQL Server базата;\n    else (Не)\n      :Празен потребителски контекст;\n    endif\n  end fork\n  &#39; Събиране на паралелните процеси\n}\n\npartition \&quot;3. Context Assembly &amp; Feature Flags\&quot; {\n  :Обединяване на данните\\n(Context-Aware Prompt);\n  \n  if (Feature Flag:\\nPromptTemplateShadowMode) then (Активен)\n    :Логване на телеметрия за\\nShadow Mode сравнение;\n  else (Неактивен)\n  endif\n}\n\npartition \&quot;4. Provider Orchestration &amp; Fallback Policy\&quot; {\n  :AiProviderClient извиква основен модел\\n(Gemini API);\n  \n  if (Успешен отговор\\nот Gemini?) then (Да)\n    :Отговорът е запазен;\n  else (Грешка / Timeout)\n    if (Feature Flag:\\nPromptTemplateFailOpen) then (True)\n      :Активиране на Fallback Policy;\n      :Извикване на резервен модел\\n(OpenAI API);\n      \n      if (Успешен отговор\\nот OpenAI?) then (Да)\n         :Отговорът е запазен\\n(Fallback Success);\n      else (Грешка)\n         :Генериране на съобщение:\\n\&quot;Временна недостъпност\&quot;;\n      endif\n    else (False - Strict Mode)\n      :Генериране на съобщение:\\n\&quot;Услугата е временно недостъпна\&quot;;\n    endif\n  endif\n}\n\npartition \&quot;5. Post-Processing &amp; Output\&quot; {\n  :AssistantResponseCompositionService;\n  :Структуриране на отговора;\n  :Инжектиране на Schema.org метаданни\\nза SEO и съвместимост;\n  :Връщане на HTTP 200 OK към Frontend (React);\n}\n\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="PA_kDRS9vijam9pdKjbV-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="1813" width="996" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
