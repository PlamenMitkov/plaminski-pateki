<mxfile host="app.diagrams.net">
  <diagram name="Страница-1" id="ZhiWH8S-I3u47J7l490i">
    <mxGraphModel grid="1" page="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" pageScale="1" pageWidth="827" pageHeight="1169" math="0" shadow="0">
      <root>
        <mxCell id="0" />
        <mxCell id="1" parent="0" />
        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle rectangle\nskinparam component {\n    BackgroundColor&lt;&lt;Middleware&gt;&gt; #E1BEE7\n    BackgroundColor&lt;&lt;Controller&gt;&gt; #BBDEFB\n    BackgroundColor&lt;&lt;Service&gt;&gt; #C8E6C9\n    BackgroundColor&lt;&lt;DTO&gt;&gt; #FFF9C4\n    BorderColor #424242\n}\nskinparam interface {\n    BackgroundColor #FFE082\n}\nskinparam arrowColor #424242\n\ntitle API Component Diagram: EcoTrails .NET 8 Web API\n\n&#39; Клиент\ninterface \&quot;HTTPS / REST\&quot; as RestAPI\n\n&#39; Middleware Pipeline\npackage \&quot;ASP.NET Core Request Pipeline\&quot; {\n    component \&quot;CORS Policy Middleware\&quot; as Cors &lt;&lt;Middleware&gt;&gt;\n    component \&quot;Exception Handling\\nMiddleware\&quot; as ErrorHandler &lt;&lt;Middleware&gt;&gt;\n    component \&quot;Authentication / JWT\\nMiddleware\&quot; as AuthMid &lt;&lt;Middleware&gt;&gt;\n}\n\n&#39; Controllers\npackage \&quot;API Controllers (Presentation Layer)\&quot; {\n    component \&quot;AssistantController\\n[Route: /api/assistant]\&quot; as AssistantCtrl &lt;&lt;Controller&gt;&gt;\n    component \&quot;TrailsController\\n[Route: /api/trails]\&quot; as TrailsCtrl &lt;&lt;Controller&gt;&gt;\n    component \&quot;UserController\\n[Route: /api/user]\&quot; as UserCtrl &lt;&lt;Controller&gt;&gt;\n}\n\n&#39; Data Transfer Objects (Contracts)\npackage \&quot;API Contracts (DTOs)\&quot; {\n    component \&quot;ChatRequestDTO\&quot; as ReqDTO &lt;&lt;DTO&gt;&gt;\n    component \&quot;StructuredResponseDTO\&quot; as ResDTO &lt;&lt;DTO&gt;&gt;\n    component \&quot;TrailModelDTO\&quot; as TrailDTO &lt;&lt;DTO&gt;&gt;\n}\n\n&#39; Core Business Services (Abstracted)\npackage \&quot;Business Logic Layer\&quot; {\n    component \&quot;OpenAiAssistantService\&quot; as AIService &lt;&lt;Service&gt;&gt;\n    component \&quot;EcoJsonImportService\&quot; as TrailsService &lt;&lt;Service&gt;&gt;\n    component \&quot;ProfileHub / Auth Service\&quot; as AuthService &lt;&lt;Service&gt;&gt;\n}\n\n&#39; Връзки - Поток на заявката\nRestAPI -down-&gt; Cors\nCors -down-&gt; ErrorHandler\nErrorHandler -down-&gt; AuthMid\n\nAuthMid -down-&gt; AssistantCtrl : \&quot;/chat\&quot;\nAuthMid -down-&gt; TrailsCtrl : \&quot;/list, /search\&quot;\nAuthMid -down-&gt; UserCtrl : \&quot;/favorites, /login\&quot;\n\n&#39; Връзки - DTOs\nAssistantCtrl .right.&gt; ReqDTO : \&quot;Очаква (POST)\&quot;\nAssistantCtrl .right.&gt; ResDTO : \&quot;Връща\&quot;\nTrailsCtrl .right.&gt; TrailDTO : \&quot;Връща колекция\&quot;\n\n&#39; Връзки към бизнес логиката\nAssistantCtrl -down-&gt; AIService : \&quot;Инжектира\&quot;\nTrailsCtrl -down-&gt; TrailsService : \&quot;Инжектира\&quot;\nUserCtrl -down-&gt; AuthService : \&quot;Инжектира\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="KH3PhQpYPxf9_zZ8GPmP-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
            <mxGeometry height="839" width="1125" x="20" y="20" as="geometry" />
          </mxCell>
        </UserObject>
      </root>
