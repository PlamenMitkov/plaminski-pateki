        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nleft to right direction\nskinparam actorStyle hollow\n\n&#39; Актьори\nactor \&quot;Нерегистриран\\nпотребител\&quot; as Guest\nactor \&quot;Регистриран\\nпотребител\&quot; as User\nactor \&quot;Администратор\&quot; as Admin\nactor \&quot;AI Провайдър\\n(Gemini/OpenAI)\&quot; as AI &lt;&lt;External System&gt;&gt;\n\n&#39; Наследяване (ПРАВИЛНАТА ПОСОКА)\n&#39; User наследява Guest (User сочи към Guest с празна стрелка)\nUser -up-|&gt; Guest\n&#39; Admin наследява User\nAdmin -up-|&gt; User\n\nrectangle \&quot;WEB Система за екопътеки\&quot; {\n    \n    &#39; Функции на госта\n    usecase \&quot;Разглеждане на екопътеки\&quot; as UC_View\n    usecase \&quot;Търсене на маршрут\&quot; as UC_Search\n    usecase \&quot;Регистрация / Вход\&quot; as UC_Auth\n    \n    &#39; Функции на регистрирания\n    usecase \&quot;Оценяване на маршрут\&quot; as UC_Rate\n    usecase \&quot;Добавяне на коментар\&quot; as UC_Comment\n    usecase \&quot;Управление на любими\&quot; as UC_Fav\n    usecase \&quot;Чат с AI асистент\&quot; as UC_Chat\n    \n    &#39; Функции на администратора\n    usecase \&quot;Управление на потребители\&quot; as UC_ManageUsers\n    usecase \&quot;Управление на маршрути\\n(Добавяне/Редактиране)\&quot; as UC_ManageRoutes\n}\n\n&#39; Връзки - Гост\nGuest --&gt; UC_View\nGuest --&gt; UC_Search\nGuest --&gt; UC_Auth\n\n&#39; Връзки - Потребител\nUser --&gt; UC_Rate\nUser --&gt; UC_Comment\nUser --&gt; UC_Fav\nUser --&gt; UC_Chat\n\n&#39; Връзки - AI (Вторичен актьор)\nUC_Chat -- AI\n\n&#39; Връзки - Администратор\nAdmin --&gt; UC_ManageUsers\nAdmin --&gt; UC_ManageRoutes\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="lDWNgOQoF89TSkoybt22-3">
