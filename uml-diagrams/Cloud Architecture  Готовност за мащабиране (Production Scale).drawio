        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam node {\n    BackgroundColor LightCyan\n    BorderColor DarkCyan\n}\nskinparam component {\n    BackgroundColor White\n    BorderColor Black\n}\nskinparam arrowColor DimGray\n\ntitle Cloud Architecture: Готовност за мащабиране (Production Scale)\n\nactor \&quot;Туристи (Mobile/Web)\&quot; as Users\n\nnode \&quot;Cloud Edge / CDN\&quot; {\n    component \&quot;Content Delivery Network\\n(Кешира React Frontend\\nза бързо зареждане)\&quot; as CDN\n}\n\nnode \&quot;Managed Kubernetes Cluster\&quot; as K8s {\n    node \&quot;API Auto-scaling Group\&quot; {\n        component \&quot;EcoTrails API Instance 1\&quot; as API1\n        component \&quot;EcoTrails API Instance 2\&quot; as API2\n        component \&quot;EcoTrails API Instance N\&quot; as APIN\n    }\n    \n    component \&quot;Load Balancer\&quot; as LB\n}\n\nnode \&quot;Managed Database Services\&quot; {\n    database \&quot;Cloud SQL Server\\n(High Availability Cluster)\&quot; as CloudSQL\n    database \&quot;Vector / Document DB\\n(Бъдеща миграция на eco.json)\&quot; as NoSQL\n}\n\ncloud \&quot;External Services\&quot; {\n    component \&quot;Gemini / OpenAI APIs\&quot; as AI\n    component \&quot;Weather Data API\&quot; as Weather\n}\n\nUsers --&gt; CDN : \&quot;Зарежда статични файлове\&quot;\nUsers --&gt; LB : \&quot;Изпраща API заявки\&quot;\n\nLB --&gt; API1\nLB --&gt; API2\nLB --&gt; APIN\n\nAPI1 --&gt; CloudSQL\nAPI1 --&gt; NoSQL\nAPI1 --&gt; AI\nAPI1 --&gt; Weather\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="7i1eku5uElY8UHqHAOl1-1">
