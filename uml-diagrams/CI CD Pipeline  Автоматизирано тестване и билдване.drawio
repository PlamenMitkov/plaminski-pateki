        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam style strictuml\nskinparam activity {\n  BackgroundColor LightCyan\n  BorderColor DarkCyan\n  ArrowColor DimGray\n}\n\ntitle CI/CD Pipeline: Автоматизирано тестване и билдване\n\nstart\n:Инженер пушва код\\n(git push origin main);\n\npartition \&quot;Continuous Integration (CI)\&quot; {\n    :Изтегляне на кода (Checkout);\n    \n    fork\n        :Setup .NET 8 SDK;\n        :dotnet restore;\n        :Компилиране на Backend (API);\n        :Изпълнение на тестове\\n(dotnet test);\n    fork again\n        :Setup Node.js;\n        :npm install;\n        :Изграждане на Frontend (Vite Build);\n    end fork\n}\n\nif (Всички тестове са успешни?) then (Не)\n    :Генериране на грешка\\nи спиране на процеса;\n    stop\nelse (Да)\nendif\n\npartition \&quot;Continuous Deployment (CD)\&quot; {\n    :Изграждане на Docker изображения\\n(API, Frontend, Database);\n    :Публикуване в Container Registry;\n    :Актуализиране на продукционната среда\\n(docker-compose up -d);\n}\n\n:Успешно внедряване;\nstop\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="9w5ma3Xn5mFCraLZxyCf-1">
          <mxCell parent="1" style="shape=image;noLabel=1;verticalAlign=top;aspect=fixed;imageAspect=0;image=data:image/svg+xml,;" vertex="1">
