        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam style strictuml\nskinparam linetype ortho\nskinparam class {\n    BackgroundColor LightYellow\n    BorderColor DarkGoldenRod\n    ArrowColor DimGray\n}\n\ntitle ER Диаграма: Хибриден модел на данните (SQL + JSON)\n\n&#39; SQL Server Entities\nentity \&quot;Users (SQL Server)\&quot; as users {\n  * Id : UNIQUEIDENTIFIER &lt;&lt;PK&gt;&gt;\n  --\n  * Username : NVARCHAR(50)\n  * Email : NVARCHAR(100)\n  * PasswordHash : NVARCHAR(MAX)\n  * CreatedAt : DATETIME2\n}\n\nentity \&quot;FavoriteTrails (SQL Server)\&quot; as favs {\n  * Id : UNIQUEIDENTIFIER &lt;&lt;PK&gt;&gt;\n  --\n  * UserId : UNIQUEIDENTIFIER &lt;&lt;FK&gt;&gt;\n  * TrailId : VARCHAR(50) &lt;&lt;External Reference&gt;&gt;\n  * AddedAt : DATETIME2\n}\n\n&#39; JSON Document Entity\nentity \&quot;Trails (eco.json)\&quot; as trails {\n  * Id : VARCHAR(50) &lt;&lt;PK&gt;&gt;\n  --\n  * Name : STRING\n  * Difficulty : STRING\n  * Coordinates : ARRAY\n  * Description : STRING\n  * Metadata : OBJECT\n}\n\n&#39; Relationships\nusers \&quot;1\&quot; -- \&quot;0..*\&quot; favs : \&quot;има (One-to-Many)\&quot;\nfavs \&quot;0..*\&quot; ..&gt; \&quot;1\&quot; trails : \&quot;реферира по ID (Soft Link)\&quot;\n\nnote right of favs\n  TrailId не е класически Foreign Key. \n  Той сочи към уникалния идентификатор\n  вътре в локалния файл eco.json.\nend note\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="-dpr3hN1d6TYSju8Unmm-1">
