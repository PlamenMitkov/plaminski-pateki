        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam node {\n    BackgroundColor LightCyan\n    BorderColor DarkCyan\n}\nskinparam component {\n    BackgroundColor White\n    BorderColor Black\n}\n\ntitle Диаграма на инфраструктурата (Deployment - Docker Compose)\n\nnode \&quot;Потребителско устройство\&quot; as ClientDevice {\n    component \&quot;Web Browser\\n(Chrome, Safari)\&quot; as Browser\n}\n\nnode \&quot;Сървърна среда (Docker Host)\&quot; as DockerHost {\n    \n    node \&quot;Docker Compose Network (eco-network)\&quot; as DockerNet {\n        \n        node \&quot;Frontend Container\&quot; as FrontendNode {\n            component \&quot;Vite Server\\n(Port: 3000/80)\&quot; as Frontend\n        }\n        \n        node \&quot;Backend Container\&quot; as BackendNode {\n            component \&quot;.NET Kestrel Server\\n(Port: 8080/443)\&quot; as Backend\n        }\n        \n        node \&quot;Database Container\&quot; as DbNode {\n            database \&quot;SQL Server\\n(Port: 1433)\&quot; as MSSQL\n        }\n    }\n    \n    storage \&quot;Docker Volume\&quot; as Volume {\n        artifact \&quot;SQL Data Persistance\\n(User accounts, Favorites)\&quot; as SqlData\n    }\n    \n    storage \&quot;Host File System\&quot; as HostFS {\n        artifact \&quot;eco.json\\n(Static Trail Data)\&quot; as LocalData\n    }\n}\n\n&#39; Мрежови връзки\nBrowser == FrontendNode : \&quot;HTTP/HTTPS\&quot;\nBrowser == BackendNode : \&quot;API Calls (REST)\&quot;\nFrontend ..&gt; Backend : \&quot;Internal Routing\&quot;\nBackend --&gt; MSSQL : \&quot;TCP 1433\&quot;\n\n&#39; Връзки към данни\nBackendNode ..&gt; HostFS : \&quot;Mounts Volume\&quot;\nMSSQL ..&gt; Volume : \&quot;Persists Data\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="OW99bDmCzuYMBm4cwsjW-1">
