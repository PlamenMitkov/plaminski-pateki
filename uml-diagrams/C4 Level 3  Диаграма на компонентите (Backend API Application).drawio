        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam componentStyle rectangle\nskinparam component {\n    BackgroundColor&lt;&lt;Controller&gt;&gt; #D4E1F9\n    BackgroundColor&lt;&lt;Service&gt;&gt; #E2F0CB\n    BackgroundColor&lt;&lt;Policy&gt;&gt; #FCE4EC\n    BackgroundColor&lt;&lt;Transport&gt;&gt; #FFF9C4\n    BorderColor #666666\n}\nskinparam databaseBackgroundColor #FFDAC1\nskinparam arrowColor #333333\n\ntitle C4 Level 3: Диаграма на компонентите (Backend API Application)\n\npackage \&quot;EcoTrails.Api (.NET 8 Web API)\&quot; {\n    \n    component \&quot;AssistantController\\n[REST Controller]\\n\\nПриема HTTP заявки\\nот Frontend-а.\&quot; as Ctrl &lt;&lt;Controller&gt;&gt;\n    \n    component \&quot;OpenAiAssistantService\\n[Component: Orchestrator]\\n\\nЦентрален мениджър на\\nAI сесиите и заявките.\&quot; as Orchestrator &lt;&lt;Service&gt;&gt;\n    \n    component \&quot;AssistantPromptSafetyService\\n[Component: Security]\\n\\nЗащитава системата от\\nprompt-injection атаки.\&quot; as Safety &lt;&lt;Policy&gt;&gt;\n    \n    component \&quot;AssistantRetrievalService\\n[Component: RAG Search]\\n\\nИзвършва хибридно търсене\\nи Anti-ambiguity филтриране.\&quot; as Retrieval &lt;&lt;Service&gt;&gt;\n    \n    component \&quot;AssistantProvenancePolicyService\\n[Component: Governance]\\n\\nПрилага политики за\\nдостоверност на източниците.\&quot; as Policy &lt;&lt;Policy&gt;&gt;\n    \n    component \&quot;AiProviderClient\\n[Component: Transport]\\n\\nУправлява HTTP връзките\\nи Fallback логиката.\&quot; as Client &lt;&lt;Transport&gt;&gt;\n    \n    component \&quot;AssistantResponseCompositionService\\n[Component: Formatter]\\n\\nСтруктурира отговора и\\nинжектира Schema.org данни.\&quot; as Composer &lt;&lt;Service&gt;&gt;\n}\n\ndatabase \&quot;eco.json\\n[Local File]\&quot; as EcoData\ncloud \&quot;Външни AI Услуги\\n(Gemini / OpenAI)\&quot; as ExtAI\n\n&#39; Поток на управлението\nCtrl ..&gt; Orchestrator : \&quot;Подава потребителско\\nсъобщение\&quot;\nOrchestrator ..&gt; Safety : \&quot;1. Проверява за\\nзлонамерен код\&quot;\nOrchestrator ..&gt; Retrieval : \&quot;2. Извлича локален\\nконтекст\&quot;\nRetrieval ..&gt; EcoData : \&quot;Чете данни\&quot;\nOrchestrator ..&gt; Policy : \&quot;3. Изолира несигурни\\nизточници\&quot;\nOrchestrator ..&gt; Client : \&quot;4. Изпълнява заявка\\nкъм модела\&quot;\nClient ..&gt; ExtAI : \&quot;HTTPS\&quot;\nOrchestrator ..&gt; Composer : \&quot;5. Форматира за\\nвизуализация\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="e-T61uz4Ps-IjEOiCI0u-1">
