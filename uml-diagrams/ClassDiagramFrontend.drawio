        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam style strictuml\nskinparam class {\n    BackgroundColor LightGreen\n    BorderColor DarkGreen\n    ArrowColor DimGray\n}\n\ntitle Frontend Component &amp; Service Diagram (React)\n\n&#39; React Components\nclass App &lt;&lt;Component&gt;&gt; {\n    + render()\n}\n\nclass HomePage &lt;&lt;Component&gt;&gt; {\n    - trails: Trail[]\n    - shouldShowOnlyFavorites: boolean\n    + toggleFavoritesMode()\n    + render()\n}\n\nclass MapWidget &lt;&lt;Component&gt;&gt; {\n    - isOffline: boolean\n    - coordinates: LatLng[]\n    + renderMarkers()\n}\n\nclass AssistantChatWidget &lt;&lt;Component&gt;&gt; {\n    - chatHistory: Message[]\n    - isTyping: boolean\n    + handleSendMessage(text: string)\n}\n\n&#39; Hooks and Services\nclass useOfflineMap &lt;&lt;Custom Hook&gt;&gt; {\n    + cacheMapTiles()\n    + getCachedTiles()\n}\n\nclass AssistantApiService &lt;&lt;Service&gt;&gt; {\n    - API_BASE_URL: string\n    + sendChatRequest(msg: string): Promise&lt;ChatResponse&gt;\n}\n\n&#39; Models/DTOs\nclass TrailData &lt;&lt;DTO&gt;&gt; {\n    + id: string\n    + name: string\n    + difficulty: string\n    + isFavorite: boolean\n}\n\n&#39; Relationships\nApp --&gt; HomePage : \&quot;renders\&quot;\nHomePage \&quot;1\&quot; *-- \&quot;1\&quot; MapWidget : \&quot;contains\&quot;\nHomePage \&quot;1\&quot; *-- \&quot;1\&quot; AssistantChatWidget : \&quot;contains\&quot;\nHomePage ..&gt; TrailData : \&quot;state\&quot;\n\nMapWidget --&gt; useOfflineMap : \&quot;uses\&quot;\nAssistantChatWidget --&gt; AssistantApiService : \&quot;calls API\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="fEXL7_4WZlyxSWJTwAzW-1">
