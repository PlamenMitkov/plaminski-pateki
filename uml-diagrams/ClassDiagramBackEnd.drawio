        <UserObject label="" plantUmlData="{&#xa;  &quot;data&quot;: &quot;@startuml\nskinparam style strictuml\nskinparam class {\n    BackgroundColor LightYellow\n    BorderColor GoldenRod\n    ArrowColor DimGray\n}\n\ntitle Backend Class Diagram: AI Assistant Architecture\n\n&#39; Interfaces (Contracts)\ninterface IAssistantPromptSafetyService &lt;&lt;Interface&gt;&gt; {\n    + ValidatePromptAsync(message: string): Task&lt;ValidationResult&gt;\n}\n\ninterface IAssistantRetrievalService &lt;&lt;Interface&gt;&gt; {\n    + BuildContextAsync(query: string): Task&lt;EnhancedContext&gt;\n}\n\ninterface IAssistantProvenancePolicyService &lt;&lt;Interface&gt;&gt; {\n    + FilterTrustedSources(data: List&lt;Trail&gt;): List&lt;Trail&gt;\n}\n\ninterface IAiProviderClient &lt;&lt;Interface&gt;&gt; {\n    + GenerateReplyAsync(context: string): Task&lt;string&gt;\n}\n\n&#39; Concrete Classes\nclass OpenAiAssistantService {\n    - _safetyService: IAssistantPromptSafetyService\n    - _retrievalService: IAssistantRetrievalService\n    - _providerClient: IAiProviderClient\n    - _provenancePolicy: IAssistantProvenancePolicyService\n    + ProcessChatRequestAsync(request: ChatRequestDTO): Task&lt;ResponseDTO&gt;\n}\n\nclass AssistantResponseCompositionService {\n    + FormatResponse(rawAiText: string): StructuredResponseDTO\n    + InjectSchemaOrgMetadata(response: StructuredResponseDTO): void\n}\n\n&#39; Relationships (Dependency Injection)\nOpenAiAssistantService ..&gt; IAssistantPromptSafetyService : &lt;&lt;injects&gt;&gt;\nOpenAiAssistantService ..&gt; IAssistantRetrievalService : &lt;&lt;injects&gt;&gt;\nOpenAiAssistantService ..&gt; IAiProviderClient : &lt;&lt;injects&gt;&gt;\nOpenAiAssistantService ..&gt; IAssistantProvenancePolicyService : &lt;&lt;injects&gt;&gt;\nOpenAiAssistantService --&gt; AssistantResponseCompositionService : \&quot;uses\&quot;\n\n@enduml&quot;,&#xa;  &quot;format&quot;: &quot;svg&quot;&#xa;}" id="EyxOvxcoU88fdAM4h68p-1">
